# This project's dependency tree is installed with bun (see bun.lock), which is
# lenient about npm peer-dependency ranges. A clean `npm ci`/`npm install` (e.g.
# in CI) otherwise fails with ERESOLVE because typescript@5.9 sits just outside
# typescript-eslint's declared peer range (<5.9.0). The pinned versions resolve
# and build/typecheck/lint cleanly in practice, so accept the existing tree.
legacy-peer-deps=true
