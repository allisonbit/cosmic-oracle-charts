# Cloudflare Workers Static Assets / Pages reads this _headers file from the
# published directory. Vite copies public/* into dist/, so this ships as
# dist/_headers. The PRIMARY deploy target (Cloudflare, wrangler.toml [assets])
# otherwise sends NO security headers — vercel.json / netlify.toml only apply on
# Vercel / Netlify. This file closes that gap on Cloudflare.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # CSP is shipped REPORT-ONLY first so it cannot white-screen the app. Ad and
  # analytics origins have been removed — only Privy/WalletConnect frames remain.
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https:; connect-src 'self' https: wss:; frame-src 'self' https://auth.privy.io https://*.privy.io https://*.walletconnect.org https://*.walletconnect.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'

# Content-hashed build assets are immutable — cache hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Keep the service worker and manifest fresh so PWA updates roll out.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=3600
